# pnpm settings for the gape monorepo.
# Auto-install peer deps; don't hard-fail on the optional plugin-react/babel peers.
auto-install-peers=true
strict-peer-dependencies=false

# three.js must resolve to a single instance across @react-three/fiber + drei,
# otherwise R3F throws "multiple instances of three". Hoist it to the root.
public-hoist-pattern[]=*three*
dedupe-peer-dependents=true
